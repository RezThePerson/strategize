---
import Card from "./Card.astro";

import Tier1 from "../../../assets/tier1.svg";
import Tier2 from "../../../assets/tier2.svg";
import Tier3 from "../../../assets/tier3.svg";
---

<div class="cards">
    <Card>
        <h1>Tier 1:</h1>
        <p>
            build a existing game, get a copy of the game! (eg. build skull, get
            skull)
        </p>
        <Tier1 />
    </Card>
    <Card>
        <h1>Tier 2:</h1>
        <p>
            bring a twist to a existing game, get a copy of the game and
            stickers! (eg. build skull but if you get 2 skulls then they cancel
            each other, get skull and stickers)
        </p>
        <Tier2 />
    </Card>
    <Card>
        <h1>Tier 3:</h1>
        <p>
            bring a a whole new game, get a phiscal creation of your game,
            stickers and a shirt! (eg. a game where you need to repel and and
            atack at the same time using cards to win, get your cards 3d
            printed, stickers and a shirt)
        </p>
        <Tier3 />
    </Card>
    <div style="display: flex;"><button> Submit Now! </button></div>
    <div class="contact">
        <h2>any question?</h2><h4>
            dm <a
                href="https://hackclub.enterprise.slack.com/team/U082KMLM7DW"
                target="_blank"
            >
                @Rez</a
            >
            on slack or ask in
            <a
                href="https://hackclub.enterprise.slack.com/archives/C0AMG0AFPJQ"
                target="_blank"
            >
                #ezample-chanel</a
            >!
        </h4>
    </div>
</div>

<style>
    .cards {
        display: flex;
        flex-direction: column;
        padding: 50px 150px;
        gap: 50px;
    }

    h1 {
        font-size: 100px;
        margin: 0px;
    }

    p {
        font-size: 50px;
        margin: 0px;
        color: #434343;
    }

    svg {
        margin-top: 15px;
        width: 100%;
    }

    .contact {
        text-align: center;
    }

    h2 {
        font-size: 100px;
        margin: 0;
    }

    h4 {
        font-size: 50px;
        margin: 0;
    }

    a {
        color: black;
    }

    button {
        border: 5px solid #c4c4c4;
        width: 100%;
        padding: 15px 0px;
        color: white;
        background-color: black;
        font-size: 50px;
        border-radius: 10px;
        cursor: pointer;
    }
</style>
